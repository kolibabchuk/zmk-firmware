CONFIG_ZMK_SPLIT=y
CONFIG_BOARD_HALLIE_LEFT=y
CONFIG_ZMK_SPLIT_ROLE_CENTRAL=y

CONFIG_SOC_SERIES_NRF52X=y
CONFIG_SOC_NRF52840_QIAA=y
CONFIG_BUILD_OUTPUT_UF2=y

CONFIG_ZMK_USB=y
CONFIG_ZMK_BLE=y

# Keyboard name (appears in Bluetooth device list)
CONFIG_ZMK_KEYBOARD_NAME="TYTS-PYZDYTS"

# USB Device IDs - Set to Apple to enable Globe key
CONFIG_USB_DEVICE_VID=0x05AC
CONFIG_USB_DEVICE_PID=0x0267
CONFIG_USB_DEVICE_MANUFACTURER="Apple Inc."

# Enable full consumer HID usage support for Globe key
CONFIG_ZMK_HID_CONSUMER_REPORT_USAGES_FULL=y

CONFIG_ARM_MPU=y
CONFIG_PINCTRL=y
CONFIG_GPIO=y
CONFIG_LED=y

CONFIG_USE_DT_CODE_PARTITION=y

CONFIG_MPU_ALLOW_FLASH_WRITE=y
CONFIG_NVS=y
CONFIG_SETTINGS_NVS=y
CONFIG_FLASH=y
CONFIG_FLASH_PAGE_LAYOUT=y
CONFIG_FLASH_MAP=y
CONFIG_CLOCK_CONTROL_NRF=y
CONFIG_CLOCK_CONTROL_NRF_K32SRC_RC=y

CONFIG_YBM=y
CONFIG_YBM_TRIGGER_GLOBAL_THREAD=y

CONFIG_ZMK_USB_LOGGING=n
CONFIG_LOG_DEFAULT_LEVEL=0
CONFIG_SENSOR_LOG_LEVEL_DBG=n

CONFIG_ZMK_IDLE_TIMEOUT=30000
CONFIG_ZMK_SLEEP=y
CONFIG_ZMK_IDLE_SLEEP_TIMEOUT=300000

CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_FETCHING=y
CONFIG_ZMK_SPLIT_BLE_CENTRAL_BATTERY_LEVEL_PROXY=y

CONFIG_ZMK_LED_WIDGETS=y

# ZMK Studio disabled - Hallie doesn't have required UART device tree config
# CONFIG_ZMK_STUDIO is not set
CONFIG_ZMK_STUDIO_LOCKING=n

CONFIG_ZMK_POINTING=y
